@using System.Text.Json
@model IEnumerable<SmartInternshipPortal.Models.Application>

@{
    ViewData["Title"] = "Student Dashboard";
    var topSkillsJson = JsonSerializer.Serialize(ViewBag.TopRequiredSkills);
    var monthlyAppsJson = JsonSerializer.Serialize(ViewBag.MonthlyApplications);
}

<div class="container-fluid">
    <!-- ================= HERO SECTION ================= -->

<div class="dashboard-hero">

    <div class="dashboard-hero-left">

        <span class="dashboard-badge">
            <i class="bi bi-stars"></i>
            AI Powered Internship Portal
        </span>

        <h1 class="dashboard-title">
            Welcome,
            @(User.Identity?.Name?.Split('@')[0])
            👋
        </h1>

        <p class="dashboard-subtitle">
            Find internships that match your skills, track every application,
            and build your career with AI-powered recommendations.
        </p>

        <div class="hero-buttons">

            <a asp-action="Browse"
               class="btn btn-primary btn-lg">

                <i class="bi bi-search"></i>

                Browse Internships

            </a>

            <a asp-action="Profile"
               class="btn btn-outline-light btn-lg">

                <i class="bi bi-person-circle"></i>

                My Profile

            </a>

        </div>

    </div>

    <div class="dashboard-hero-right">

        <div class="hero-card">

            <div class="hero-card-icon">

                <i class="bi bi-briefcase-fill"></i>

            </div>

            <h2>@ViewBag.TotalInternships</h2>

            <p>Live Internships</p>

        </div>

    </div>

</div>

<!-- ================= END HERO ================= -->

    <!-- ================= DASHBOARD STATS ================= -->

<div class="stats-grid">

    <div class="stat-card">

        <div class="stat-icon bg-primary">

            <i class="bi bi-briefcase-fill"></i>

        </div>

        <div class="stat-content">

            <h3>@ViewBag.TotalInternships</h3>

            <p>Total Internships</p>

        </div>

    </div>

    <div class="stat-card">

        <div class="stat-icon bg-success">

            <i class="bi bi-send-check-fill"></i>

        </div>

        <div class="stat-content">

            <h3>@ViewBag.Applications</h3>

            <p>Applications</p>

        </div>

    </div>

    <div class="stat-card">

        <div class="stat-icon bg-warning">

            <i class="bi bi-hourglass-split"></i>

        </div>

        <div class="stat-content">

            <h3>@ViewBag.PendingApplications</h3>

            <p>Pending</p>

        </div>

    </div>

    <div class="stat-card">

        <div class="stat-icon bg-info">

            <i class="bi bi-check-circle-fill"></i>

        </div>

        <div class="stat-content">

            <h3>@ViewBag.AcceptedApplications</h3>

            <p>Accepted</p>

        </div>

    </div>

    <div class="stat-card">

        <div class="stat-icon bg-danger">

            <i class="bi bi-x-circle-fill"></i>

        </div>

        <div class="stat-content">

            <h3>@ViewBag.RejectedApplications</h3>

            <p>Rejected</p>

        </div>

    </div>

</div>

<!-- ================= END STATS ================= -->
<!-- ================= QUICK ACTIONS ================= -->

<div class="widget-card mt-4">

    <div class="widget-header">

        <h2>

            <i class="bi bi-lightning-charge-fill"></i>

            Quick Actions

        </h2>

    </div>

    <div class="widget-body">

        <div class="quick-actions-grid">

            <a asp-action="Browse" class="quick-action-card">

                <i class="bi bi-search"></i>

                <span>Browse Internships</span>

            </a>

            <a asp-action="Profile" class="quick-action-card">

                <i class="bi bi-person-circle"></i>

                <span>My Profile</span>

            </a>

            <a asp-action="MySavedJobs" class="quick-action-card">

                <i class="bi bi-bookmark-heart"></i>

                <span>Saved Jobs</span>

            </a>

            <a asp-action="Profile" class="quick-action-card">

                <i class="bi bi-file-earmark-arrow-up"></i>

                <span>Upload Resume</span>

            </a>

            <a asp-action="Settings" class="quick-action-card">

                <i class="bi bi-gear-fill"></i>

                <span>Settings</span>

            </a>

            <a asp-action="Browse" class="quick-action-card">

                <i class="bi bi-building"></i>

                <span>Companies</span>

            </a>

        </div>

    </div>

</div>

<!-- ================= END QUICK ACTIONS ================= -->

<!-- ================= RESUME COMPLETION ================= -->

<div class="row mt-4">

    <div class="col-lg-6">

        <div class="widget-card">

            <div class="widget-header">
                <h2>
                    <i class="bi bi-file-earmark-person"></i>
                    Resume Completion
                </h2>
            </div>

            <div class="widget-body">

                <h3 class="mb-3">85% Complete</h3>

                <div class="progress" style="height:18px;">

                    <div class="progress-bar bg-success"
                         role="progressbar"
                         style="width:85%">
                    </div>

                </div>

                <ul class="mt-4">

                    <li>✔ Profile Completed</li>

                    <li>✔ Skills Added</li>

                    <li>✔ Resume Uploaded</li>

                    <li>⚠ Add More Projects</li>

                    <li>⚠ Add Certifications</li>

                </ul>

                <a asp-action="Profile"
                   class="btn btn-primary mt-3">

                    Update Profile

                </a>

            </div>

        </div>

    </div>
        <div class="col-lg-6">

        <div class="widget-card">

            <div class="widget-header">

                <h2>

                    <i class="bi bi-clock-history"></i>

                    Recent Activity

                </h2>

            </div>

            <div class="widget-body">

                <div class="activity-item">

                    <i class="bi bi-check-circle-fill text-success"></i>

                    Applied for Google Data Engineer Internship

                </div>

                <div class="activity-item">

                    <i class="bi bi-upload text-primary"></i>

                    Resume Updated

                </div>

                <div class="activity-item">

                    <i class="bi bi-star-fill text-warning"></i>

                    New Internship Recommendation

                </div>

                <div class="activity-item">

                    <i class="bi bi-person-check-fill text-info"></i>

                    Profile Completed

                </div>

            </div>

        </div>

    </div>

</div>

<!-- ================= TOP COMPANIES ================= -->

<div class="widget-card mt-4">

    <div class="widget-header d-flex justify-content-between">

        <h2>

            <i class="bi bi-building"></i>

            Top Companies Hiring

        </h2>

        <a asp-action="Browse" class="btn btn-primary">

            View All

        </a>

    </div>

    <div class="widget-body">

        <div class="companies-grid">

            <div class="company-card">

                <img src="~/images/company-logos/google.svg"
                     class="company-logo-large">

                <h4>Google</h4>

                <p>8 Open Internships</p>

            </div>

            <div class="company-card">

                <img src="~/images/company-logos/microsoft.svg"
                     class="company-logo-large">

                <h4>Microsoft</h4>

                <p>5 Open Internships</p>

            </div>

            <div class="company-card">

                <img src="~/images/company-logos/amazon.svg"
                     class="company-logo-large">

                <h4>Amazon</h4>

                <p>12 Open Internships</p>

            </div>

            <div class="company-card">

                <img src="~/images/company-logos/infosys.svg"
                     class="company-logo-large">

                <h4>Infosys</h4>

                <p>15 Open Internships</p>

            </div>

        </div>

    </div>

</div>

    <!-- Charts Section (Moved to appear before Matches) -->
    <div class="row mt-4">
        <div class="col-lg-6">
            <div class="widget-card">
                <div class="widget-header"><h2><i class="bi bi-bar-chart-fill"></i> Top Required Skills</h2></div>
                <div class="widget-body"><canvas id="skillsChart" height="250"></canvas></div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="widget-card">
                <div class="widget-header"><h2><i class="bi bi-graph-up-arrow"></i> Monthly Applications</h2></div>
                <div class="widget-body"><canvas id="monthlyChart" height="250"></canvas></div>
            </div>
        </div>
    </div>

    <!-- Smart Internship Matches -->
    <!-- ================= SMART INTERNSHIP MATCHES ================= -->

<div class="widget-card mt-5">

    <div class="widget-header d-flex justify-content-between align-items-center">

        <h2>
            <i class="bi bi-stars"></i>
            AI Smart Internship Matches
        </h2>

        <a asp-action="Browse" class="btn btn-primary">
            View All
        </a>

    </div>

    <div class="widget-body">

        @if (ViewBag.Recommendations != null && ViewBag.Recommendations.Count > 0)
        {
            @foreach (var rec in (IEnumerable<SmartInternshipPortal.Controllers.RecommendationViewModel>)ViewBag.Recommendations)
            {
<div class="internship-card">

    <div class="row align-items-center">

        <!-- Left Side -->
        <div class="col-lg-9">

            <div class="d-flex">

                <!-- Company Logo -->
                <div class="company-logo">

                    @{
                        var recCompanyName = rec.Internship.Company.FullName as string ?? string.Empty;
                        var recCompanyFileName = new string(recCompanyName.ToLower().Where(c => char.IsLetterOrDigit(c) || c == ' ').ToArray()).Replace(" ", "-");
                        var recCompanyLogoPath = System.IO.Path.Combine(System.IO.Directory.GetCurrentDirectory(), "wwwroot", "images", "company-logos", $"{recCompanyFileName}.svg");
                        var recCompanyLogoSrc = $"/images/company-logos/{recCompanyFileName}.svg";
                        var recHasCompanyLogo = System.IO.File.Exists(recCompanyLogoPath);
                    }
                    @if (recHasCompanyLogo)
                    {
                        <img src="@recCompanyLogoSrc"
                             class="company-logo-img"
                             alt="@rec.Internship.Company.FullName" />
                    }
                    else if (!string.IsNullOrEmpty(rec.Internship.Company.CompanyLogo))
                    {
                        <img src="@rec.Internship.Company.CompanyLogo"
                             class="company-logo-img"
                             alt="@rec.Internship.Company.FullName" />
                    }
                    else
                    {
                        <div class="company-placeholder">
                            @rec.Internship.Company.FullName.Substring(0,1)
                        </div>
                    }

                </div>

                <!-- Internship Details -->
                <div class="ms-4">

                    <h3 class="job-title">
                        @rec.Internship.Title
                    </h3>

                    <h5 class="company-name">
                        @rec.Internship.Company.FullName
                    </h5>

                    <p class="job-info">

                        <i class="bi bi-geo-alt"></i>

                        @rec.Internship.Location

                        &nbsp;&nbsp;

                        <i class="bi bi-calendar3"></i>

                        @rec.Internship.PostedDate.ToString("dd MMM yyyy")

                    </p>

                    <div class="skills-list">

                        @foreach (var skill in rec.Internship.InternshipSkills)
                        {
                            <span class="badge bg-primary me-2">
                                @skill.Skill.Name
                            </span>
                        }

                    </div>

                    <div class="mt-3">

                        <a asp-action="Details"
                           asp-route-id="@rec.Internship.Id"
                           class="btn btn-primary">

                            View Role

                        </a>

                        <a asp-action="CompanyDetails"
                           asp-route-id="@rec.Internship.CompanyId"
                           class="btn btn-outline-light ms-2">

                            Company

                        </a>

                    </div>

                </div>

            </div>

        </div>

        <!-- Right Side -->

        <div class="col-lg-3 text-end">

            <div class="match-circle">

                <h2>@rec.MatchScore%</h2>

                <span>Match</span>

            </div>

        </div>

    </div>

</div>

            }
        }
        else
        {
            <div class="empty-state text-center py-5">

                <i class="bi bi-search display-1 text-secondary"></i>

                <h3 class="mt-3">No Matching Internships</h3>

                <p class="text-muted">
                    Update your profile and skills to receive AI recommendations.
                </p>

                <a asp-action="Browse" class="btn btn-primary mt-3">
                    Browse Internships
                </a>

            </div>
        }

    </div> <!-- widget-body -->

</div> <!-- widget-card -->

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Data serialized from ViewBag
            const topSkillsRaw = @Html.Raw(topSkillsJson);
            const monthlyAppsRaw = @Html.Raw(monthlyAppsJson);

            // 1. Top Required Skills Chart (Bar Chart)
            const skillsLabels = topSkillsRaw.map(x => x.Name);
            const skillsData = topSkillsRaw.map(x => x.Count);

            const skillsCtx = document.getElementById('skillsChart').getContext('2d');
            new Chart(skillsCtx, {
                type: 'bar',
                data: {
                    labels: skillsLabels,
                    datasets: [{
                        label: 'Required count',
                        data: skillsData,
                        backgroundColor: 'rgba(56, 189, 248, 0.25)',
                        borderColor: '#38bdf8',
                        borderWidth: 1.5,
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: 'rgba(255, 255, 255, 0.05)' },
                            ticks: { 
                                color: '#94a3b8',
                                font: { size: 10 }
                            }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { 
                                color: '#94a3b8',
                                font: { size: 10 }
                            }
                        }
                    }
                }
            });

            // 2. Monthly Applications Chart (Line Chart)
            const monthlyLabels = monthlyAppsRaw.map(x => x.Label);
            const monthlyData = monthlyAppsRaw.map(x => x.Count);

            const monthlyCtx = document.getElementById('monthlyChart').getContext('2d');
            new Chart(monthlyCtx, {
                type: 'line',
                data: {
                    labels: monthlyLabels,
                    datasets: [{
                        label: 'Applications',
                        data: monthlyData,
                        borderColor: '#22d3ee',
                        backgroundColor: 'rgba(34, 211, 238, 0.05)',
                        borderWidth: 2,
                        tension: 0.35,
                        fill: true,
                        pointBackgroundColor: '#22d3ee'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: 'rgba(255, 255, 255, 0.05)' },
                            ticks: { 
                                color: '#94a3b8',
                                font: { size: 10 },
                                stepSize: 1
                            }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { 
                                color: '#94a3b8',
                                font: { size: 10 }
                            }
                        }
                    }
                }
            });
        });
    </script>
}