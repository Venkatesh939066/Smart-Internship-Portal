@using SmartInternshipPortal.Models

@{
    ViewData["Title"] = "Manage Skills";

    var allSkills = ViewBag.AllSkills as List<Skill>;
    var selectedSkillIds = ViewBag.SelectedSkillIds as List<int>;
}

<h2>Manage Skills</h2>

<form asp-action="UpdateSkills" method="post">

    @if (allSkills != null)
    {
        foreach (var skill in allSkills)
        {
            <div class="form-check">

                <input class="form-check-input"
                       type="checkbox"
                       name="selectedSkillIds"
                       value="@skill.Id"
                       @(selectedSkillIds != null && selectedSkillIds.Contains(skill.Id) ? "checked" : "") />

                <label class="form-check-label">
                    @skill.Name
                </label>

            </div>
        }
    }

    <br />

    <button type="submit" class="btn btn-primary" style="display: inline-flex; align-items: center; gap: 8px;">
        <i class="bi bi-check-circle"></i> Save Skills
    </button>

    <a asp-action="EditProfile" class="btn btn-secondary">
        Cancel
    </a>

</form>