@model SmartInternshipPortal.Models.ApplicationUser
@{
    ViewData["Title"] = "Company Profile";
}

<div class="dashboard-wrapper">
    <div class="dashboard-header-card">
        <div class="header-text">
            <h1>Company Profile Settings 🏢</h1>
            <p>Update your public company profile details so candidates can learn more about your organization.</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn-secondary-custom">🔙 Back to Workspace</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-custom success mb-4">
            <span>🎉 @TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="form-container-card">
        <div class="widget-card">
            <div class="widget-header">
                <h2>Profile Details</h2>
            </div>
            <div class="widget-body">
                <form asp-action="Profile" method="post" class="auth-form full-width-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger-summary"></div>

                    <div class="form-grid-two-cols">
                        <div class="form-group-custom">
                            <label for="fullName">Company Name</label>
                            <input type="text" id="fullName" name="fullName" value="@Model.FullName" placeholder="e.g. Google" required />
                        </div>

                        <div class="form-grid-two-cols" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
                            <div class="form-group-custom">
                                <label for="companyIndustry">Industry</label>
                                <input type="text" id="companyIndustry" name="companyIndustry" value="@Model.CompanyIndustry" placeholder="e.g. Tech, Finance" />
                            </div>
                            <div class="form-group-custom">
                                <label for="companyWebsite">Career / Job Portal URL</label>
                                <input type="url" id="companyWebsite" name="companyWebsite" value="@Model.CompanyWebsite" placeholder="e.g. https://careers.example.com/jobs" />
                            </div>
                        </div>
                    </div>

                    <div class="form-group-custom mt-3">
                        <label for="companyDescription">About Our Company</label>
                        <textarea id="companyDescription" name="companyDescription" rows="6" placeholder="Describe your company's mission, values, size, and what it is like to work here...">@Model.CompanyDescription</textarea>
                    </div>

                    <div class="form-actions-row mt-4">
                        <button type="submit" class="btn-primary-custom">Save Profile Settings</button>
                        <a asp-action="Index" class="btn-secondary-custom">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
