@{
    ViewData["Title"] = "Post Internship";
    var allSkills = ViewBag.AllSkills as IEnumerable<SmartInternshipPortal.Models.Skill>;
}
<div class="dashboard-wrapper">
    <div class="dashboard-header-card">
        <div class="header-text">
            <h1>Post Internship Opportunity 📢</h1>
            <p>Create a job listing and check the required skills. Students matching these skills will be matched automatically.</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn-secondary-custom">🔙 Back to Dashboard</a>
        </div>
    </div>
    <div class="form-container-card">
        <div class="widget-card">
            <div class="widget-header">
                <h2>Listing Details</h2>
            </div>
            <div class="widget-body">
                <form asp-action="Create" method="post" class="auth-form full-width-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger-summary"></div>
                    <div class="form-grid-two-cols">
                        <div class="form-group-custom">
                            <label for="title">Internship Title</label>
                            <input type="text" id="title" name="title" placeholder="e.g. Software Engineer Intern" required />
                        </div>
                        <div class="form-group-custom">
                            <label for="location">Location</label>
                            <input type="text" id="location" name="location" placeholder="e.g. Remote, San Francisco, CA" required />
                        </div>
                    </div>
                    <div class="form-group-custom mt-3">
                        <label for="description">Job Description</label>
                        <textarea id="description" name="description" rows="6" placeholder="Describe the responsibilities, daily tasks, requirements, and benefits of this internship..." required></textarea>
                    </div>
                    <div class="form-grid-two-cols mt-3">

    <div class="form-group-custom">
        <label>Experience Level</label>
        <select name="experienceLevel" required>
            <option value="">Select</option>
            <option value="Fresher">Fresher</option>
            <option value="Beginner">Beginner</option>
            <option value="Intermediate">Intermediate</option>
        </select>
    </div>

    <div class="form-group-custom">
        <label>Salary</label>
        <input type="text"
               name="salary"
               placeholder="e.g. ₹20,000/month" />
    </div>

</div>
                    <div class="form-group-custom mt-4">
                        <label>Select Required Skills:</label>
                        <p class="form-instructions">Only students matching these will be calculated with higher match scores.</p>
                        
                        <div class="form-grid-two-cols mt-3">

                        <div class="skills-checkbox-grid">
                            @if (allSkills != null)
                            {
                                foreach (var skill in allSkills)
                                {
                                    <label class="skill-checkbox-container">
                                        <input type="checkbox" name="selectedSkillIds" value="@skill.Id" />
                                        <span class="skill-checkbox-box">
                                            <span class="checkbox-indicator"></span>
                                            <span class="skill-name">@skill.Name</span>
                                        </span>
                                    </label>
                                }
                            }
                        </div>
                    </div>
                    <div class="form-actions-row mt-4">
                        <button type="submit" class="btn-primary-custom">Publish Internship</button>
                        <a asp-action="Index" class="btn-secondary-custom">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
