@model SmartInternshipPortal.Models.Internship
@{
    ViewData["Title"] = "Edit Internship";
    var allSkills = ViewBag.AllSkills as IEnumerable<SmartInternshipPortal.Models.Skill>;
    var selectedSkillIds = ViewBag.SelectedSkillIds as List<int> ?? new List<int>();
}
<div class="dashboard-wrapper">
    <div class="dashboard-header-card">
        <div class="header-text">
            <h1>Edit Internship Listing ✏️</h1>
            <p>Update posting details and required skills so student matches stay current.</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn-secondary-custom">🔙 Back to Dashboard</a>
        </div>
    </div>

    <div class="form-container-card">
        <div class="widget-card">
            <div class="widget-header">
                <h2>Listing Details</h2>
            </div>
            <div class="widget-body">
                <form asp-action="Edit" method="post" class="auth-form full-width-form">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="form-grid-two-cols">
                        <div class="form-group-custom">
                            <label for="title">Internship Title</label>
                            <input type="text" id="title" name="title" value="@Model.Title" required />
                        </div>
                        <div class="form-group-custom">
                            <label for="location">Location</label>
                            <input type="text" id="location" name="location" value="@Model.Location" required />
                        </div>
                    </div>

                    <div class="form-group-custom mt-3">
                        <label for="description">Job Description</label>
                        <textarea id="description" name="description" rows="6" required>@Model.Description</textarea>
                    </div>

                    <div class="form-grid-two-cols mt-3">
                        <div class="form-group-custom">
                            <label>Experience Level</label>
                            <select name="experienceLevel" required>
                                <option value="Fresher" selected="@(Model.ExperienceLevel == "Fresher")">Fresher</option>
                                <option value="Beginner" selected="@(Model.ExperienceLevel == "Beginner")">Beginner</option>
                                <option value="Intermediate" selected="@(Model.ExperienceLevel == "Intermediate")">Intermediate</option>
                            </select>
                        </div>
                        <div class="form-group-custom">
                            <label>Salary</label>
                            <input type="text" name="salary" value="@Model.Salary" placeholder="e.g. ₹20,000/month" />
                        </div>
                    </div>

                    <div class="form-grid-two-cols mt-3">
                        <div class="form-group-custom">
                            <label>Job Type</label>
                            <input type="text" name="jobType" value="@Model.JobType" placeholder="e.g. Internship" />
                        </div>
                        <div class="form-group-custom">
                            <label>Remote Type</label>
                            <input type="text" name="remoteType" value="@Model.RemoteType" placeholder="e.g. Remote" />
                        </div>
                    </div>

                    <div class="form-grid-two-cols mt-3">
                        <div class="form-group-custom">
                            <label>Apply URL</label>
                            <input type="text" name="applyUrl" value="@Model.ApplyUrl" placeholder="https://example.com/apply" />
                        </div>
                        <div class="form-group-custom">
                            <label>Deadline</label>
                            <input type="date" name="deadline" value="@Model.Deadline.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>

                    <div class="form-group-custom mt-4">
                        <label>Select Required Skills</label>
                        <div class="form-grid-two-cols mt-3">
                            <div class="skills-checkbox-grid">
                                @if (allSkills != null)
                                {
                                    foreach (var skill in allSkills)
                                    {
                                        <label class="skill-checkbox-container">
                                            <input type="checkbox" name="selectedSkillIds" value="@skill.Id" @(selectedSkillIds.Contains(skill.Id) ? "checked" : "") />
                                            <span class="skill-checkbox-box">
                                                <span class="checkbox-indicator"></span>
                                                <span class="skill-name">@skill.Name</span>
                                            </span>
                                        </label>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <div class="form-actions-row mt-4">
                        <button type="submit" class="btn-primary-custom">Save Changes</button>
                        <a asp-action="Index" class="btn-secondary-custom">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>