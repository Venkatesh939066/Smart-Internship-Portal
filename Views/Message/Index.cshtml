@model List<SmartInternshipPortal.Models.Message>
@{
    var currentUser = ViewBag.CurrentUser as SmartInternshipPortal.Models.ApplicationUser;
    var otherUser = ViewBag.OtherUser as SmartInternshipPortal.Models.ApplicationUser;
    ViewData["Title"] = $"Chat with {otherUser?.FullName}";
    var otherInitial = string.IsNullOrWhiteSpace(otherUser?.FullName) ? "U" : otherUser.FullName.Trim()[0].ToString().ToUpper();
    var isCompany = currentUser?.Role == "Company";
}

<div class="chat-outer-container">
    <div class="chat-header-card">
        <div class="chat-user-profile">
            <div class="chat-avatar-circle">
                @if (otherUser != null && !string.IsNullOrEmpty(otherUser.ProfileImage))
                {
                    <img src="@otherUser.ProfileImage" alt="@otherUser.FullName" class="chat-avatar-img" />
                }
                else
                {
                    <span>@otherInitial</span>
                }
            </div>
            <div class="chat-user-details">
                <h3>@otherUser?.FullName</h3>
                <span class="chat-user-badge">@(otherUser?.Role == "Company" ? "Recruiter" : "Applicant")</span>
            </div>
        </div>
        <div>
            <a href="@(isCompany ? "/Company/Applicants" : "/Student/Index")" class="chat-back-btn">
                <i class="bi bi-arrow-left-short"></i> Back
            </a>
        </div>
    </div>

    <div class="chat-messages-container" id="chatMessages">
        @if (Model.Any())
        {
            @foreach (var message in Model)
            {
                var isSender = message.SenderId == currentUser?.Id;
                <div class="chat-bubble-row @(isSender ? "outgoing" : "incoming")">
                    <div class="chat-bubble">
                        <div class="chat-content">@message.Content</div>
                        <div class="chat-time">@message.SentAt.ToString("g")</div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="chat-empty-state">
                <div class="chat-empty-icon">💬</div>
                <h4>Start the conversation</h4>
                <p>Send a message to begin discussing internship opportunities.</p>
            </div>
        }
    </div>

    <div class="chat-input-bar">
        <form asp-controller="Message" asp-action="Send" method="post" class="d-flex w-100 gap-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="receiverId" value="@otherUser?.Id" />
            <input type="text" name="content" class="chat-text-input" placeholder="Type a message..." required autocomplete="off" />
            <button type="submit" class="chat-send-btn">
                <i class="bi bi-send-fill"></i>
            </button>
        </form>
    </div>
</div>

<style>
    .chat-outer-container {
        display: flex;
        flex-direction: column;
        height: calc(100vh - var(--topbar-height) - 40px);
        background: var(--bg-elevated);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        overflow: hidden;
        backdrop-filter: blur(16px);
        box-shadow: var(--shadow-lg);
    }

    .chat-header-card {
        padding: 16px 24px;
        background: rgba(17, 24, 39, 0.6);
        border-bottom: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .chat-user-profile {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .chat-avatar-circle {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--accent-gradient);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        font-weight: 700;
        font-size: 16px;
        overflow: hidden;
        border: 2px solid rgba(255, 255, 255, 0.1);
    }

    .chat-avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .chat-user-details h3 {
        font-size: 16px;
        font-weight: 700;
        margin: 0 0 2px 0;
        color: var(--text-main);
    }

    .chat-user-badge {
        font-size: 11px;
        font-weight: 600;
        background: rgba(56, 189, 248, 0.15);
        color: var(--primary);
        padding: 1px 8px;
        border-radius: 12px;
    }

    .chat-back-btn {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-main);
        border: 1px solid var(--border-color);
        padding: 6px 14px;
        border-radius: var(--radius-sm);
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 4px;
        transition: all 0.2s;
    }

    .chat-back-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        color: var(--primary);
    }

    .chat-messages-container {
        flex: 1;
        padding: 24px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 16px;
        background: rgba(11, 17, 32, 0.4);
    }

    .chat-bubble-row {
        display: flex;
        width: 100%;
    }

    .chat-bubble-row.outgoing {
        justify-content: flex-end;
    }

    .chat-bubble-row.incoming {
        justify-content: flex-start;
    }

    .chat-bubble {
        max-width: 60%;
        padding: 12px 16px;
        border-radius: 18px;
        position: relative;
        box-shadow: var(--shadow-sm);
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .outgoing .chat-bubble {
        background: var(--accent);
        background: var(--accent-gradient);
        color: #ffffff;
        border-bottom-right-radius: 4px;
    }

    .incoming .chat-bubble {
        background: var(--bg-elevated);
        border: 1px solid var(--border-color);
        color: var(--text-main);
        border-bottom-left-radius: 4px;
    }

    .chat-content {
        font-size: 14px;
        line-height: 1.5;
        word-break: break-word;
    }

    .chat-time {
        font-size: 10px;
        opacity: 0.7;
        align-self: flex-end;
    }

    .chat-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        text-align: center;
        color: var(--text-muted);
    }

    .chat-empty-icon {
        font-size: 48px;
        margin-bottom: 12px;
    }

    .chat-empty-state h4 {
        color: var(--text-main);
        font-weight: 700;
        margin-bottom: 6px;
    }

    .chat-input-bar {
        padding: 16px 24px;
        background: rgba(17, 24, 39, 0.6);
        border-top: 1px solid var(--border-color);
    }

    .chat-text-input {
        flex: 1;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border-color);
        color: var(--text-main);
        border-radius: 24px;
        padding: 12px 20px;
        font-size: 14px;
        outline: none;
        transition: all 0.2s;
    }

    .chat-text-input:focus {
        border-color: var(--primary);
        background: rgba(255, 255, 255, 0.08);
        box-shadow: 0 0 12px rgba(56, 189, 248, 0.15);
    }

    .chat-send-btn {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        background: var(--accent-gradient);
        border: none;
        color: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: var(--shadow-sm);
    }

    .chat-send-btn:hover {
        transform: scale(1.05);
        box-shadow: 0 0 16px rgba(37, 99, 235, 0.4);
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var container = document.getElementById('chatMessages');
        if (container) {
            container.scrollTop = container.scrollHeight;
        }
    });
</script>
