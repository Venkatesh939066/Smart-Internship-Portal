@model IEnumerable<SmartInternshipPortal.Models.ApplicationUser>
@{
    ViewData["Title"] = "Companies Directory";
    var companyStats = ViewBag.CompanyStats as Dictionary<string, int> ?? new Dictionary<string, int>();
    var isAuthenticated = ViewBag.IsAuthenticated == true;
    var currentUserId = ViewBag.CurrentUserId as string;
}

<div class="container py-5">
    <div class="directory-header text-center mb-5">
        <span class="badge-directory"><i class="bi bi-building"></i> Corporate Directory</span>
        <h1 class="directory-title">Interact with Top Recruiting Companies</h1>
        <p class="directory-subtitle text-muted">Browse all seeded Indian MNCs & startup partners. Access their profiles, chat directly, or log in to manage/modify internships.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var company in Model)
            {
                var jobCount = companyStats.TryGetValue(company.Id, out var count) ? count : 0;
                
                <div class="col-md-6 col-lg-4">
                    <div class="company-directory-card">
                        <div class="card-top">
                            <div class="company-logo-circle" style="overflow: hidden; display: flex; align-items: center; justify-content: center; background: #2a2f3b;">
                                @{
                                    var cName = company.FullName as string ?? string.Empty;
                                    var cFileName = new string(cName.ToLower().Where(c => char.IsLetterOrDigit(c) || c == ' ').ToArray()).Replace(" ", "-");
                                    var cLogoPath = System.IO.Path.Combine(System.IO.Directory.GetCurrentDirectory(), "wwwroot", "images", "company-logos", $"{cFileName}.svg");
                                    var cLogoSrc = $"/images/company-logos/{cFileName}.svg";
                                    var cHasLogo = System.IO.File.Exists(cLogoPath);
                                }
                                @if (cHasLogo)
                                {
                                    <img src="@cLogoSrc" alt="@company.FullName logo" style="width: 100%; height: 100%; object-fit: contain; padding: 4px;" />
                                }
                                else
                                {
                                    @(string.IsNullOrWhiteSpace(company.FullName) ? "C" : company.FullName.Substring(0, 1).ToUpper())
                                }
                            </div>
                            <div class="company-intro">
                                <h4 class="company-name">@company.FullName</h4>
                                <span class="industry-badge">@company.CompanyIndustry</span>
                            </div>
                        </div>
                        
                        <div class="card-body-custom mt-3">
                            <p class="company-description text-muted">
                                @(string.IsNullOrEmpty(company.CompanyDescription) 
                                    ? "This partner company leverages SmartInternship's AI matching database to screen candidate profiles and conduct technical reviews." 
                                    : company.CompanyDescription)
                            </p>
                            
                            <div class="company-stats-row d-flex justify-content-between mt-3 mb-3">
                                <span class="stat-lbl"><i class="bi bi-briefcase text-primary"></i> Active Roles: <strong>@jobCount</strong></span>
                                <span class="stat-lbl"><i class="bi bi-envelope text-info"></i> @company.Email</span>
                            </div>
                        </div>
                        
                        <div class="card-actions-grid d-flex flex-wrap gap-2 pt-3 border-top">
                            <a asp-controller="Home" asp-action="CompanyDetails" asp-route-id="@company.Id" class="btn btn-outline-primary btn-sm flex-fill">
                                <i class="bi bi-eye"></i> View Profile
                            </a>
                            
                            @if (isAuthenticated && currentUserId != company.Id)
                            {
                                <a asp-controller="Message" asp-action="Index" asp-route-withUserId="@company.Id" class="btn btn-primary btn-sm flex-fill">
                                    <i class="bi bi-chat-dots"></i> Chat
                                </a>
                            }
                            else if (!isAuthenticated)
                            {
                                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-sm flex-fill">
                                    <i class="bi bi-chat-dots"></i> Chat
                                </a>
                            }

                            <!-- Impersonate/Manage Login Shortcut to Modify Internships -->
                            <a asp-controller="Account" asp-action="SimulateLogin" asp-route-email="@company.Email" class="btn btn-warning btn-sm w-100 mt-2 btn-sim-login" onclick="return confirm('impersonate login as @company.FullName to manage and edit internships?');">
                                <i class="bi bi-shield-lock-fill"></i> Simulate Login: Manage Jobs
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">No companies found in database.</p>
            </div>
        }
    </div>
</div>

<style>
    .badge-directory {
        background: rgba(2, 132, 199, 0.1);
        color: #0284c7;
        font-weight: 700;
        text-transform: uppercase;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 12px;
        display: inline-block;
        margin-bottom: 12px;
    }
    .directory-title {
        font-size: 32px;
        font-weight: 800;
        color: #0f172a;
    }
    .directory-subtitle {
        font-size: 15px;
        max-width: 600px;
        margin: 10px auto 0;
    }

    /* Company directory card styling */
    .company-directory-card {
        background: #ffffff;
        border: 1px solid rgba(148, 163, 184, 0.15);
        border-radius: 16px;
        padding: 24px;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .company-directory-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 20px -5px rgba(0,0,0,0.08);
    }
    .card-top {
        display: flex;
        align-items: center;
        gap: 15px;
    }
    .company-logo-circle {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        background: #0284c7;
        color: #ffffff;
        font-weight: 800;
        font-size: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 10px rgba(2, 132, 199, 0.2);
    }
    .company-intro {
        overflow: hidden;
    }
    .company-name {
        margin: 0;
        font-size: 18px;
        font-weight: 700;
        color: #1e293b;
        white-space: nowrap;
        text-overflow: ellipsis;
        overflow: hidden;
    }
    .industry-badge {
        background: #f1f5f9;
        color: #475569;
        font-size: 11px;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 4px;
        display: inline-block;
        margin-top: 4px;
    }

    .company-description {
        font-size: 12.5px;
        line-height: 1.5;
        margin: 10px 0 0;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 56px;
    }
    .company-stats-row {
        font-size: 12px;
        color: #64748b;
    }
    .stat-lbl strong {
        color: #0f172a;
    }

    .btn-sim-login {
        font-size: 12px;
        font-weight: 600;
        background: #fef3c7;
        color: #d97706;
        border: 1px solid #fde68a;
        transition: background 0.2s, color 0.2s;
    }
    .btn-sim-login:hover {
        background: #fde68a;
        color: #b45309;
        border-color: #fcd34d;
    }
</style>
