@model IEnumerable<SmartInternshipPortal.Models.Internship>

@{
    ViewData["Title"] = "AI Powered Internship Portal";
}

<div class="container-fluid">
    <div class="dashboard-hero">
        <div>
            <span class="dashboard-badge">AI Powered Internship Portal</span>
            <h1 class="dashboard-title">Welcome to Smart Internship Portal</h1>
            <p class="dashboard-subtitle">Discover internships, improve your profile, and track your applications.</p>
        </div>
        <div>
            <a asp-controller="Student" asp-action="Browse" class="btn btn-primary"><i class="bi bi-search"></i> Browse Internships</a>
            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light">Get Started</a>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-lg-3"><div class="dashboard-card"><h2>@ViewBag.InternshipsCount</h2><p>Total Internships</p></div></div>
        <div class="col-lg-3"><div class="dashboard-card"><h2>@ViewBag.ApplicationsCount</h2><p>Total Applications</p></div></div>
        <div class="col-lg-3"><div class="dashboard-card success"><h2>@ViewBag.StudentsCount</h2><p>Active Students</p></div></div>
        <div class="col-lg-3"><div class="dashboard-card warning"><h2>@ViewBag.CompaniesCount</h2><p>Partner Companies</p></div></div>
    </div>

    <div class="widget-card mt-5">
        <div class="widget-header">
            <h2><i class="bi bi-briefcase-fill"></i> Latest Internship Openings</h2>
        </div>
        <div class="widget-body">
            @if (Model != null && Model.Any())
            {
                @foreach (var internship in Model)
                {
                    <div class="card shadow-sm border-0 mb-4 internship-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <div class="company-logo me-3" style="width: 70px; height: 70px; background: #2a2f3b; display: flex; align-items: center; justify-content: center; border-radius: 8px; overflow: hidden;">
                                        @{
                                            var homeCompanyName = internship.Company?.FullName as string ?? string.Empty;
                                            var homeCompanyFileName = new string(homeCompanyName.ToLower().Where(c => char.IsLetterOrDigit(c) || c == ' ').ToArray()).Replace(" ", "-");
                                            var homeCompanyLogoPath = System.IO.Path.Combine(System.IO.Directory.GetCurrentDirectory(), "wwwroot", "images", "company-logos", $"{homeCompanyFileName}.svg");
                                            var homeCompanyLogoSrc = $"/images/company-logos/{homeCompanyFileName}.svg";
                                            var homeHasCompanyLogo = System.IO.File.Exists(homeCompanyLogoPath);
                                        }
                                        @if (homeHasCompanyLogo)
                                        {
                                            <img src="@homeCompanyLogoSrc" alt="@internship.Company?.FullName logo" style="width: 100%; height: 100%; object-fit: contain; padding: 4px;" />
                                        }
                                        else
                                        {
                                            <span class="text-white fw-bold" style="font-size: 1.5rem;">
                                                @(string.IsNullOrEmpty(internship.Company?.FullName) ? "C" : internship.Company.FullName.Substring(0, 1).ToUpper())
                                            </span>
                                        }
                                    </div>
                                    <div class="ms-2">
                                        <h4 class="fw-bold mb-1" style="font-size: 1.25rem;">@internship.Title</h4>
                                        <h5 class="text-primary mb-2" style="font-size: 1rem;">@(internship.Company?.FullName ?? "Unknown Company")</h5>
                                        <div class="text-muted mb-2 small">
                                            <i class="bi bi-geo-alt-fill"></i> @internship.Location &nbsp;&nbsp;
                                            <i class="bi bi-calendar-event"></i> @internship.PostedDate.ToString("dd MMM yyyy")
                                        </div>
                                        <div class="mb-3">
                                            @foreach (var skill in internship.InternshipSkills)
                                            {
                                                <span class="badge bg-primary me-2 mb-1">@skill.Skill.Name</span>
                                            }
                                        </div>
                                        <div class="d-flex gap-2">
                                            <a asp-controller="Home" asp-action="CompanyDetails" asp-route-id="@internship.CompanyId" class="btn btn-sm btn-outline-secondary">Company</a>
                                            <a asp-controller="Student" asp-action="Details" asp-route-id="@internship.Id" class="btn btn-sm btn-primary">View Role</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-4">
                    <i class="bi bi-search" style="font-size: 3rem; color: #4b5563;"></i>
                    <h4 class="mt-3">No Internships Available</h4>
                    <p class="text-muted small">Check back later or register to post/browse internships.</p>
                </div>
            }
        </div>
    </div>
</div>