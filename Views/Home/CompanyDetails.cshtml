@model SmartInternshipPortal.Models.ApplicationUser
@{
    ViewData["Title"] = $"{Model.FullName} Profile";
    var listingItems = ViewBag.ListingItems as List<dynamic> ?? new List<dynamic>();
    var isAdmin = ViewBag.IsAdmin == true;
    var isCompany = ViewBag.IsCompany == true;
    var currentUserId = ViewBag.CurrentUserId as string;
    var isSelf = currentUserId == Model.Id;
}

<div class="container py-5">
    <div class="mb-4">
        <a asp-controller="Home" asp-action="Companies" class="btn btn-link ps-0 text-decoration-none">
            <i class="bi bi-arrow-left"></i> Back to Corporate Directory
        </a>
    </div>

    <!-- Company Profile Header Card -->
    <div class="company-profile-header-card mb-5">
        <div class="row g-4 align-items-center">
            <div class="col-auto">
                <div class="company-profile-logo" style="overflow: hidden; display: flex; align-items: center; justify-content: center; background: #2a2f3b;">
                    @{
                        var compName = Model.FullName as string ?? string.Empty;
                        var compFileName = new string(compName.ToLower().Where(c => char.IsLetterOrDigit(c) || c == ' ').ToArray()).Replace(" ", "-");
                        var compLogoPath = System.IO.Path.Combine(System.IO.Directory.GetCurrentDirectory(), "wwwroot", "images", "company-logos", $"{compFileName}.svg");
                        var compLogoSrc = $"/images/company-logos/{compFileName}.svg";
                        var compHasLogo = System.IO.File.Exists(compLogoPath);
                    }
                    @if (compHasLogo)
                    {
                        <img src="@compLogoSrc" alt="@Model.FullName logo" style="width: 100%; height: 100%; object-fit: contain; padding: 4px;" />
                    }
                    else
                    {
                        @(string.IsNullOrWhiteSpace(Model.FullName) ? "C" : Model.FullName.Substring(0, 1).ToUpper())
                    }
                </div>
            </div>
            <div class="col">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <h1 class="company-profile-title mb-0">@Model.FullName</h1>
                    <span class="badge-role-company">Verified Recruiter</span>
                </div>
                <p class="company-meta-subtitle text-muted mt-1 mb-0">
                    <span class="me-3"><i class="bi bi-tag-fill text-primary"></i> @Model.CompanyIndustry</span>
                    <span><i class="bi bi-globe text-info"></i> <a href="@Model.CompanyWebsite" target="_blank" class="text-decoration-none text-muted">@Model.CompanyWebsite</a></span>
                </p>
            </div>
            <div class="col-md-auto text-end">
                @if (isSelf)
                {
                    <a asp-controller="Company" asp-action="Profile" class="btn btn-outline-secondary">
                        <i class="bi bi-pencil"></i> Edit Profile
                    </a>
                }
                else if (isAdmin)
                {
                    <a asp-controller="Account" asp-action="SimulateLogin" asp-route-email="@Model.Email" class="btn btn-warning">
                        <i class="bi bi-shield-lock-fill"></i> Simulate Manage
                    </a>
                }
            </div>
        </div>
        
        <div class="company-profile-about mt-4 pt-4 border-top">
            <h5 class="fw-bold text-dark"><i class="bi bi-info-circle-fill text-primary me-2"></i> About the Company</h5>
            <p class="text-muted leading-relaxed mt-2 mb-0">
                @(string.IsNullOrEmpty(Model.CompanyDescription)
                    ? "This company screens student profiles and manages active recruitment pipelines using SmartInternship's AI matching database."
                    : Model.CompanyDescription)
            </p>
        </div>
    </div>

    <!-- Active Openings Section -->
    <div class="row">
        <div class="col-12">
            <h3 class="fw-bold mb-4"><i class="bi bi-briefcase-fill text-primary me-2"></i> Active Internship Roles (@listingItems.Count)</h3>
            
            <div class="internships-list-column">
                @if (listingItems.Any())
                {
                    foreach (var item in listingItems)
                    {
                        var internship = item.Internship;
                        int matchScore = item.MatchScore;
                        bool hasApplied = item.HasApplied;
                        
                        <div class="internship-item-card p-4 mb-3 border rounded shadow-sm bg-white">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                                <div>
                                    <h4 class="fw-bold mb-1 text-dark">@internship.Title</h4>
                                    <div class="d-flex gap-3 text-muted fs-7 my-2 flex-wrap">
                                        <span><i class="bi bi-geo-alt text-danger"></i> @internship.Location</span>
                                        <span><i class="bi bi-wallet2 text-success"></i> @internship.Salary</span>
                                        <span><i class="bi bi-calendar2-check text-info"></i> Posted @internship.PostedDate.ToString("dd MMM yyyy")</span>
                                    </div>
                                    
                                    <div class="internship-skills-row d-flex flex-wrap gap-2 mt-3">
                                        @foreach (var skill in internship.InternshipSkills)
                                        {
                                            <span class="badge bg-light text-dark border">@skill.Skill.Name</span>
                                        }
                                    </div>
                                </div>
                                
                                <div class="text-end d-flex flex-column align-items-end gap-2">
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill fw-bold">
                                        <i class="bi bi-stars"></i> @matchScore% AI Match
                                    </span>
                                    
                                    <div class="d-flex gap-2 mt-2">
                                        @if (isSelf || isAdmin)
                                        {
                                            <!-- Modify/Edit Internship Shortcut -->
                                            <a asp-controller="Company" asp-action="Edit" asp-route-id="@internship.Id" class="btn btn-outline-warning btn-sm">
                                                <i class="bi bi-pencil-square"></i> Modify Role
                                            </a>
                                            <a asp-controller="Company" asp-action="Delete" asp-route-id="@internship.Id" class="btn btn-outline-danger btn-sm" onclick="return confirm('Are you sure you want to delete this internship?');">
                                                <i class="bi bi-trash"></i> Delete
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-controller="Student" asp-action="Details" asp-route-id="@internship.Id" class="btn btn-primary btn-sm px-3">
                                                <i class="bi bi-eye"></i> View Details / Apply
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 border rounded bg-light">
                        <i class="bi bi-info-circle text-muted fs-1 mb-3"></i>
                        <p class="text-muted mb-0">No active internships posted by this company yet.</p>
                        @if (isSelf)
                        {
                            <a asp-controller="Company" asp-action="Create" class="btn btn-primary mt-3">
                                <i class="bi bi-plus-circle"></i> Post Your First Internship
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .badge-role-company {
        background: rgba(16, 185, 129, 0.15);
        color: #10b981;
        font-weight: 700;
        font-size: 11px;
        padding: 4px 10px;
        border-radius: 12px;
        border: 1px solid rgba(16, 185, 129, 0.25);
    }
    .company-profile-header-card {
        background: #ffffff;
        border: 1px solid rgba(148, 163, 184, 0.15);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }
    .company-profile-logo {
        width: 80px;
        height: 80px;
        border-radius: 16px;
        background: #0284c7;
        color: #ffffff;
        font-weight: 800;
        font-size: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 16px rgba(2, 132, 199, 0.25);
    }
    .company-profile-title {
        font-size: 28px;
        font-weight: 800;
        color: #0f172a;
    }
    .company-meta-subtitle {
        font-size: 13.5px;
    }

    .internship-item-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .internship-item-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 15px rgba(0, 0, 0, 0.05) !important;
    }
    .fs-7 {
        font-size: 13px;
    }
</style>
